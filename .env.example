# ── Optional: Supabase (cloud database) ─────────────────────────────
# Without these, Beat the Book runs in Local Mode (data saved in your browser).
# Create a free project at https://supabase.com, then run supabase/schema.sql
# in the SQL editor and paste your keys here (in a file named .env.local).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic API (powers the AI Agent chat + Bet Slip OCR) ──────────
# Required for the AI Agent chat. Without it, the chat shows setup steps
# and the Bet Slip Importer falls back to manual entry.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
